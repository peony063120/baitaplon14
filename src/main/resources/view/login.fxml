<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<VBox spacing="20" alignment="CENTER" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.LoginController">

    <padding>
        <Insets top="40" right="40" bottom="40" left="40"/>
    </padding>

    <VBox alignment="CENTER" spacing="10">
        <Text text="Online Auction System" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-fill: #2c3e50;">
        </Text>
        <Text text="Login to your account" style="-fx-font-size: 14; -fx-fill: #6c757d;">
        </Text>
    </VBox>

    <VBox spacing="15">
        <TextField fx:id="usernameField" promptText="Username"
                   style="-fx-pref-height: 40; -fx-padding: 8 12; -fx-border-color: #ced4da; -fx-border-radius: 5;"/>

        <PasswordField fx:id="passwordField" promptText="Password"
                       style="-fx-pref-height: 40; -fx-padding: 8 12; -fx-border-color: #ced4da; -fx-border-radius: 5;"/>

        <Label fx:id="statusLabel" style="-fx-padding: 5; -fx-font-size: 12;"/>

        <Button fx:id="loginButton" text="Login" onAction="#handleLogin"
                style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-pref-height: 40; -fx-font-weight: bold; -fx-background-radius: 5;"/>

        <Button fx:id="registerButton" text="Create New Account" onAction="#handleRegister"
                style="-fx-background-color: transparent; -fx-text-fill: #6c757d; -fx-border-color: #6c757d; -fx-border-radius: 5; -fx-pref-height: 36;"/>
    </VBox>

</VBox>