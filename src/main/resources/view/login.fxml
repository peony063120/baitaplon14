<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.*?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           prefWidth="800" prefHeight="600"
           style="-fx-background-color: #0C447C;">

    <!-- Decoration circles -->
    <Circle radius="200" fill="#185FA5" opacity="0.4"
            translateX="-280" translateY="-180"/>
    <Circle radius="150" fill="#378ADD" opacity="0.25"
            translateX="300" translateY="200"/>
    <Circle radius="80" fill="#85B7EB" opacity="0.2"
            translateX="250" translateY="-220"/>

    <!-- Login card -->
    <VBox alignment="CENTER" spacing="0"
          maxWidth="400" maxHeight="520"
          style="-fx-background-color: white;
                 -fx-background-radius: 16;
                 -fx-padding: 40 48 36 48;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 30, 0, 0, 8);">

        <!-- Logo + title -->
        <VBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 28 0;">
            <StackPane>
                <Circle radius="28"
                        style="-fx-fill: #E6F1FB;"/>
                <Label text="⚒"
                       style="-fx-font-size: 22; -fx-text-fill: #185FA5;"/>
            </StackPane>
            <Label text="Online Auction System"
                   style="-fx-font-size: 20; -fx-font-weight: bold;
                          -fx-text-fill: #0C447C;"/>
            <Label text="Đăng nhập vào tài khoản của bạn"
                   style="-fx-font-size: 13; -fx-text-fill: #85B7EB;"/>
        </VBox>

        <!-- Username -->
        <VBox spacing="6" style="-fx-padding: 0 0 14 0;">
            <Label text="Tên đăng nhập"
                   style="-fx-font-size: 12; -fx-font-weight: bold;
                          -fx-text-fill: #444;"/>
            <TextField promptText="Nhập username..."
                       prefHeight="42" maxWidth="Infinity"
                       style="-fx-background-color: #f5f7fa;
                              -fx-border-color: #dce3ea;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 0 14; -fx-font-size: 13;"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="6" style="-fx-padding: 0 0 24 0;">
            <Label text="Mật khẩu"
                   style="-fx-font-size: 12; -fx-font-weight: bold;
                          -fx-text-fill: #444;"/>
            <PasswordField promptText="Nhập mật khẩu..."
                           prefHeight="42" maxWidth="Infinity"
                           style="-fx-background-color: #f5f7fa;
                                  -fx-border-color: #dce3ea;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 0 14; -fx-font-size: 13;"/>
        </VBox>

        <!-- Login button -->
        <Button text="Đăng nhập"
                maxWidth="Infinity" prefHeight="44"
                style="-fx-background-color: #185FA5;
                       -fx-text-fill: white; -fx-font-size: 14;
                       -fx-font-weight: bold; -fx-background-radius: 8;
                       -fx-cursor: hand;"/>

        <!-- Forgot password -->
        <HBox alignment="CENTER" style="-fx-padding: 14 0 0 0;">
            <Label text="Quên mật khẩu? "
                   style="-fx-font-size: 12; -fx-text-fill: #999;"/>
            <Label text="Khôi phục ngay"
                   style="-fx-font-size: 12; -fx-text-fill: #185FA5;
                          -fx-cursor: hand; -fx-underline: true;"/>
        </HBox>

        <!-- Divider -->
        <HBox alignment="CENTER" spacing="10" style="-fx-padding: 20 0 20 0;">
            <Line endX="100" stroke="#e0e6ee"/>
            <Label text="hoặc" style="-fx-font-size: 12; -fx-text-fill: #bbb;"/>
            <Line endX="100" stroke="#e0e6ee"/>
        </HBox>

        <!-- Register button -->
        <Button text="Tạo tài khoản mới"
                maxWidth="Infinity" prefHeight="42"
                style="-fx-background-color: white;
                       -fx-text-fill: #185FA5; -fx-font-size: 13;
                       -fx-font-weight: bold;
                       -fx-border-color: #378ADD; -fx-border-radius: 8;
                       -fx-background-radius: 8; -fx-cursor: hand;"/>

    </VBox>
</StackPane>