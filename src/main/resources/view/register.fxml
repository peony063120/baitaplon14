<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane xmlns:fx="http://javafx.com/fxml"
           fx:controller="com.yourapp.RegisterController"
           prefWidth="800" prefHeight="700"
           style="-fx-background-color: #0C447C;">

    <!-- Register card -->
    <VBox alignment="CENTER" spacing="0"
          maxWidth="420"
          style="-fx-background-color: white;
                 -fx-background-radius: 16;
                 -fx-padding: 36 48 32 48;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 30, 0, 0, 8);">

        <!-- Title -->
        <VBox alignment="CENTER" spacing="6" style="-fx-padding: 0 0 24 0;">
            <StackPane alignment="CENTER" prefWidth="56" prefHeight="56">
                <Circle radius="28" fill="#E6F1FB"/>
                <Label text="⚒" style="-fx-font-size: 22; -fx-text-fill: #185FA5;"/>
            </StackPane>
            <Label text="Tạo tài khoản mới"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #0C447C;"/>
            <Label text="Điền thông tin để đăng ký"
                   style="-fx-font-size: 13; -fx-text-fill: #85B7EB;"/>
        </VBox>

        <!-- Full Name -->
        <VBox spacing="6" style="-fx-padding: 0 0 12 0;">
            <Label text="Họ và tên"
                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #444;"/>
            <TextField fx:id="fullNameField"
                       promptText="Nhập họ và tên..."
                       prefHeight="40" maxWidth="Infinity"
                       style="-fx-background-color: #f5f7fa;
                              -fx-border-color: #dce3ea;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 0 14; -fx-font-size: 13;"/>
        </VBox>

        <!-- Username -->
        <VBox spacing="6" style="-fx-padding: 0 0 12 0;">
            <Label text="Tên đăng nhập"
                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #444;"/>
            <TextField fx:id="usernameField"
                       promptText="Nhập username..."
                       prefHeight="40" maxWidth="Infinity"
                       style="-fx-background-color: #f5f7fa;
                              -fx-border-color: #dce3ea;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 0 14; -fx-font-size: 13;"/>
        </VBox>

        <!-- Email -->
        <VBox spacing="6" style="-fx-padding: 0 0 12 0;">
            <Label text="Email"
                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #444;"/>
            <TextField fx:id="emailField"
                       promptText="Nhập email..."
                       prefHeight="40" maxWidth="Infinity"
                       style="-fx-background-color: #f5f7fa;
                              -fx-border-color: #dce3ea;
                              -fx-border-radius: 8; -fx-background-radius: 8;
                              -fx-padding: 0 14; -fx-font-size: 13;"/>
        </VBox>

        <!-- Password -->
        <VBox spacing="6" style="-fx-padding: 0 0 12 0;">
            <Label text="Mật khẩu"
                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #444;"/>
            <PasswordField fx:id="passwordField"
                           promptText="Nhập mật khẩu..."
                           prefHeight="40" maxWidth="Infinity"
                           style="-fx-background-color: #f5f7fa;
                                  -fx-border-color: #dce3ea;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 0 14; -fx-font-size: 13;"/>
        </VBox>

        <!-- Confirm Password -->
        <VBox spacing="6" style="-fx-padding: 0 0 12 0;">
            <Label text="Xác nhận mật khẩu"
                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #444;"/>
            <PasswordField fx:id="confirmPasswordField"
                           promptText="Nhập lại mật khẩu..."
                           prefHeight="40" maxWidth="Infinity"
                           style="-fx-background-color: #f5f7fa;
                                  -fx-border-color: #dce3ea;
                                  -fx-border-radius: 8; -fx-background-radius: 8;
                                  -fx-padding: 0 14; -fx-font-size: 13;"/>
        </VBox>

        <!-- Select Role -->
        <VBox spacing="6" style="-fx-padding: 0 0 24 0;">
            <Label text="Vai trò"
                   style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #444;"/>
            <ComboBox fx:id="roleComboBox"
                      promptText="Chọn vai trò..."
                      maxWidth="Infinity" prefHeight="40"
                      style="-fx-background-color: #f5f7fa;
                             -fx-border-color: #dce3ea;
                             -fx-border-radius: 8; -fx-background-radius: 8;
                             -fx-font-size: 13;"/>
        </VBox>

        <!-- Register button -->
        <Button fx:id="registerButton"
                text="Đăng ký"
                onAction="#handleRegister"
                maxWidth="Infinity" prefHeight="44"
                style="-fx-background-color: #185FA5;
                       -fx-text-fill: white; -fx-font-size: 14;
                       -fx-font-weight: bold; -fx-background-radius: 8;
                       -fx-cursor: hand;"/>

        <!-- Back to login -->
        <HBox alignment="CENTER" style="-fx-padding: 14 0 0 0;">
            <Label text="Đã có tài khoản? "
                   style="-fx-font-size: 12; -fx-text-fill: #999;"/>
            <Label fx:id="loginLink"
                   text="Đăng nhập ngay"
                   onMouseClicked="#handleGoToLogin"
                   style="-fx-font-size: 12; -fx-text-fill: #185FA5;
                          -fx-cursor: hand; -fx-underline: true;"/>
        </HBox>

    </VBox>
</StackPane>