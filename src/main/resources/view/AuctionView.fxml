<?xml version="1.0" encoding="UTF-8"?>

<!--
  Vestige — Digital Auction House
  JavaFX FXML translation of the Obsidian Authority web design.
  Controller: com.vestige.AuctionController
  Pair with auction.css (see /mnt/documents/auction.css) via scene.getStylesheets().
-->

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.vestige.AuctionController"
            styleClass="root-bg"
            prefWidth="1440" prefHeight="1024">

    <!-- ============== TOP NAV ============== -->
    <top>
        <HBox styleClass="navbar" alignment="CENTER_LEFT" spacing="32">
            <padding><Insets top="16" right="24" bottom="16" left="24"/></padding>

            <HBox alignment="CENTER_LEFT" spacing="32">
                <Label text="VESTIGE" styleClass="brand"/>
                <HBox spacing="24" alignment="CENTER_LEFT">
                    <Label text="Live Auctions" styleClass="nav-link"/>
                    <Label text="Private Sales"  styleClass="nav-link"/>
                    <Label text="Provenance"     styleClass="nav-link"/>
                </HBox>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <HBox alignment="CENTER_RIGHT" spacing="16">
                <Label text="USER ID: 882-AX" styleClass="user-chip"/>
                <Button text="LIVE ROOM" styleClass="btn-primary"/>
            </HBox>
        </HBox>
    </top>

    <!-- ============== MAIN ============== -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="scroll-clean">
            <VBox spacing="0" styleClass="main-col">

                <!-- HERO -->
                <GridPane styleClass="hero" hgap="0" vgap="0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="66"/>
                        <ColumnConstraints percentWidth="34"/>
                    </columnConstraints>

                    <!-- Hero left -->
                    <VBox spacing="24" styleClass="hero-left"
                          GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Region styleClass="dot-live"/>
                            <Label text="GLOBAL FEATURE • LOT 402" styleClass="eyebrow"/>
                        </HBox>

                        <Label text="GRAND COMPLICATION No. 12" styleClass="hero-title" wrapText="true"/>
                        <Label text="VACHERON &amp; CONSTANTIN"  styleClass="hero-title-muted" wrapText="true"/>

                        <StackPane styleClass="hero-image-wrap">
                            <ImageView fitWidth="900" preserveRatio="true" pickOnBounds="true">
                                <image>
                                    <Image url="@assets/hero-watch.jpg"/>
                                </image>
                            </ImageView>
                        </StackPane>
                    </VBox>

                    <!-- Hero right (bid panel) -->
                    <VBox styleClass="hero-right" spacing="48"
                          GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

                        <VBox spacing="32">
                            <VBox spacing="6">
                                <Label text="CURRENT BID" styleClass="caption-mono"/>
                                <Label fx:id="currentBidLabel" text="$1,420,000" styleClass="bid-amount"/>
                                <Label text="Reserve Met" styleClass="reserve-met"/>
                            </VBox>

                            <VBox spacing="12">
                                <HBox alignment="BOTTOM_LEFT">
                                    <Label text="ENDS IN" styleClass="caption-mono"/>
                                    <Region HBox.hgrow="ALWAYS"/>
                                    <Label fx:id="countdownLabel" text="04:12:09" styleClass="countdown"/>
                                </HBox>
                                <Separator styleClass="hairline"/>
                                <ProgressBar fx:id="timeBar" progress="0.72" prefWidth="9999" styleClass="time-bar"/>
                            </VBox>
                        </VBox>

                        <Region VBox.vgrow="ALWAYS"/>

                        <VBox spacing="12">
                            <Button fx:id="placeBidBtn"  text="PLACE BID"        styleClass="btn-light"  maxWidth="Infinity"/>
                            <Button fx:id="watchlistBtn" text="ADD TO WATCHLIST" styleClass="btn-ghost"  maxWidth="Infinity"/>
                        </VBox>
                    </VBox>
                </GridPane>

                <!-- LIVE LOTS -->
                <VBox spacing="32" styleClass="section">
                    <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

                    <HBox alignment="BOTTOM_LEFT">
                        <Label text="LIVE LOTS" styleClass="section-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="3 active items" styleClass="caption-mono"/>
                    </HBox>

                    <GridPane hgap="1" vgap="1" styleClass="lot-grid">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="33.34"/>
                            <ColumnConstraints percentWidth="33.33"/>
                            <ColumnConstraints percentWidth="33.33"/>
                        </columnConstraints>
                        <rowConstraints>
                            <RowConstraints/>
                        </rowConstraints>

                        <!-- LOT 102 -->
                        <VBox styleClass="lot-card" spacing="16"
                              GridPane.columnIndex="0" GridPane.rowIndex="0">
                            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                            <StackPane styleClass="lot-image-wrap">
                                <ImageView fitWidth="400" preserveRatio="true">
                                    <image><Image url="@assets/lot-sculpture.jpg"/></image>
                                </ImageView>
                            </StackPane>
                            <HBox alignment="TOP_LEFT">
                                <VBox spacing="2">
                                    <Label text="ARP STUDY #4" styleClass="lot-title"/>
                                    <Label text="Jean Arp, c. 1954" styleClass="lot-sub"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Lot 102" styleClass="lot-tag"/>
                            </HBox>
                            <Separator styleClass="hairline"/>
                            <HBox alignment="BOTTOM_LEFT">
                                <VBox spacing="2">
                                    <Label text="CURRENT" styleClass="caption-mono"/>
                                    <Label text="$12,400" styleClass="lot-price"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <VBox spacing="2" alignment="BOTTOM_RIGHT">
                                    <Label text="TIME" styleClass="caption-mono"/>
                                    <Label text="12m 04s" styleClass="lot-time"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- LOT 103 -->
                        <VBox styleClass="lot-card" spacing="16"
                              GridPane.columnIndex="1" GridPane.rowIndex="0">
                            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                            <StackPane styleClass="lot-image-wrap">
                                <ImageView fitWidth="400" preserveRatio="true">
                                    <image><Image url="@assets/lot-camera.jpg"/></image>
                                </ImageView>
                            </StackPane>
                            <HBox alignment="TOP_LEFT">
                                <VBox spacing="2">
                                    <Label text="LEICA M3 'BLACK PAINT'" styleClass="lot-title"/>
                                    <Label text="Serial #991 224" styleClass="lot-sub"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Lot 103" styleClass="lot-tag"/>
                            </HBox>
                            <Separator styleClass="hairline"/>
                            <HBox alignment="BOTTOM_LEFT">
                                <VBox spacing="2">
                                    <Label text="CURRENT" styleClass="caption-mono"/>
                                    <Label text="$45,000" styleClass="lot-price"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <VBox spacing="2" alignment="BOTTOM_RIGHT">
                                    <Label text="TIME" styleClass="caption-mono"/>
                                    <Label text="01h 45m" styleClass="lot-time"/>
                                </VBox>
                            </HBox>
                        </VBox>

                        <!-- LOT 104 -->
                        <VBox styleClass="lot-card" spacing="16"
                              GridPane.columnIndex="2" GridPane.rowIndex="0">
                            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                            <StackPane styleClass="lot-image-wrap">
                                <ImageView fitWidth="400" preserveRatio="true">
                                    <image><Image url="@assets/lot-chair.jpg"/></image>
                                </ImageView>
                            </StackPane>
                            <HBox alignment="TOP_LEFT">
                                <VBox spacing="2">
                                    <Label text="EAMES ORIGINAL 1956" styleClass="lot-title"/>
                                    <Label text="Herman Miller, Rosewood" styleClass="lot-sub"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="Lot 104" styleClass="lot-tag"/>
                            </HBox>
                            <Separator styleClass="hairline"/>
                            <HBox alignment="BOTTOM_LEFT">
                                <VBox spacing="2">
                                    <Label text="CURRENT" styleClass="caption-mono"/>
                                    <Label text="$8,200" styleClass="lot-price"/>
                                </VBox>
                                <Region HBox.hgrow="ALWAYS"/>
                                <VBox spacing="2" alignment="BOTTOM_RIGHT">
                                    <Label text="TIME" styleClass="caption-mono"/>
                                    <Label text="04h 22m" styleClass="lot-time"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </GridPane>
                </VBox>

                <!-- PROVENANCE + BID HISTORY -->
                <GridPane styleClass="split-section" hgap="0" vgap="0">
                    <columnConstraints>
                        <ColumnConstraints percentWidth="50"/>
                        <ColumnConstraints percentWidth="50"/>
                    </columnConstraints>

                    <!-- Provenance -->
                    <VBox spacing="32" styleClass="provenance"
                          GridPane.columnIndex="0" GridPane.rowIndex="0">
                        <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

                        <Label text="PROVENANCE &amp; DETAILS" styleClass="overline"/>
                        <Label wrapText="true" styleClass="provenance-body"
                               text="Acquired directly from the artist's estate in 1974. Exhibited at the Venice Biennale, this particular piece represents the peak of the post-war minimalist movement. Documented in the official catalogue raisonné under entry 182-B."/>

                        <Separator styleClass="hairline"/>

                        <GridPane hgap="32" vgap="8">
                            <columnConstraints>
                                <ColumnConstraints percentWidth="50"/>
                                <ColumnConstraints percentWidth="50"/>
                            </columnConstraints>
                            <VBox spacing="6" GridPane.columnIndex="0" GridPane.rowIndex="0">
                                <Label text="CONDITION" styleClass="caption-mono"/>
                                <Label text="Excellent, original patina preserved." styleClass="meta-value"/>
                            </VBox>
                            <VBox spacing="6" GridPane.columnIndex="1" GridPane.rowIndex="0">
                                <Label text="DIMENSIONS" styleClass="caption-mono"/>
                                <Label text="124cm x 88cm x 4cm" styleClass="meta-value"/>
                            </VBox>
                        </GridPane>
                    </VBox>

                    <!-- Bid History -->
                    <VBox spacing="32" styleClass="bid-history"
                          GridPane.columnIndex="1" GridPane.rowIndex="0">
                        <padding><Insets top="48" right="48" bottom="48" left="48"/></padding>

                        <Label text="BID HISTORY" styleClass="overline"/>

                        <VBox fx:id="bidHistoryList" spacing="12">
                            <HBox styleClass="bid-row" alignment="CENTER_LEFT">
                                <Label text="BIDDER 410" styleClass="bidder"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="$1,420,000" styleClass="bid-value"/>
                                <Region prefWidth="24"/>
                                <Label text="04:12 PM" styleClass="bid-time"/>
                            </HBox>
                            <HBox styleClass="bid-row dim-1" alignment="CENTER_LEFT">
                                <Label text="BIDDER 092" styleClass="bidder"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="$1,400,000" styleClass="bid-value"/>
                                <Region prefWidth="24"/>
                                <Label text="04:11 PM" styleClass="bid-time"/>
                            </HBox>
                            <HBox styleClass="bid-row dim-2" alignment="CENTER_LEFT">
                                <Label text="BIDDER 410" styleClass="bidder"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label text="$1,350,000" styleClass="bid-value"/>
                                <Region prefWidth="24"/>
                                <Label text="04:08 PM" styleClass="bid-time"/>
                            </HBox>
                        </VBox>

                        <VBox styleClass="next-increment" spacing="16">
                            <padding><Insets top="24" right="24" bottom="24" left="24"/></padding>
                            <Label text="NEXT INCREMENT" styleClass="overline-accent"/>
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <Label text="$1,440,000" styleClass="next-amount"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button fx:id="quickBidBtn" text="QUICK BID" styleClass="btn-primary"/>
                            </HBox>
                        </VBox>
                    </VBox>
                </GridPane>

                <!-- FOOTER -->
                <Pane styleClass="hairline-top"/>
                <HBox alignment="CENTER" styleClass="footer">
                    <padding><Insets top="48" right="24" bottom="48" left="24"/></padding>
                    <Label text="© 2024 VESTIGE DIGITAL AUCTIONS — AUTHORIZED GLOBAL EXCHANGE"
                           styleClass="footer-text"/>
                </HBox>
            </VBox>
        </ScrollPane>
    </center>
</BorderPane>
