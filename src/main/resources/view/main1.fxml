<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox prefHeight="700" prefWidth="900"
      style="-fx-background-color: #f0f2f5;"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/17.0.12"
      fx:controller="com.auction.client.controller.AuctionController">

   <!-- ===== HEADER ===== -->
   <VBox style="-fx-background-color: #0C447C; -fx-padding: 22 28 0 28;">
      <HBox alignment="CENTER_LEFT" spacing="12">
         <StackPane prefWidth="36" prefHeight="36"
                    style="-fx-background-color: #185FA5; -fx-background-radius: 8;">
            <Label text="⚒" style="-fx-font-size: 18; -fx-text-fill: #E6F1FB;"/>
         </StackPane>
         <VBox spacing="2" HBox.hgrow="ALWAYS">
            <Label text="Online Auction System"
                   style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #E6F1FB;"/>
            <Label text="Welcome to the auction platform"
                   style="-fx-font-size: 12; -fx-text-fill: #85B7EB;"/>
         </VBox>
         <HBox spacing="10" alignment="CENTER_RIGHT">
            <Label fx:id="lblUsername" text="—"
                   style="-fx-background-color: rgba(255,255,255,0.15);
                              -fx-border-color: rgba(255,255,255,0.25);
                              -fx-border-radius: 20; -fx-background-radius: 20;
                              -fx-padding: 6 14; -fx-font-size: 13;
                              -fx-text-fill: #E6F1FB;"/>
            <Button fx:id="btnLogout" text="Logout"
                    onAction="#handleLogout"
                    style="-fx-background-color: rgba(255,255,255,0.12);
                               -fx-border-color: rgba(255,255,255,0.3);
                               -fx-border-radius: 8; -fx-background-radius: 8;
                               -fx-padding: 7 16; -fx-font-size: 13;
                               -fx-text-fill: #E6F1FB; -fx-cursor: hand;"/>
         </HBox>
      </HBox>

      <!-- Stats bar -->
      <HBox style="-fx-padding: 14 0 0 0;">
         <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="2"
               style="-fx-padding: 0 0 14 0;">
            <Label fx:id="statTotal" text="—"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #E6F1FB;"/>
            <Label text="DANG DAU GIA"
                   style="-fx-font-size: 10; -fx-text-fill: #85B7EB;"/>
         </VBox>
         <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="2"
               style="-fx-padding: 0 0 14 0;">
            <Label fx:id="statMyBids" text="—"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #E6F1FB;"/>
            <Label text="BID CUA TOI"
                   style="-fx-font-size: 10; -fx-text-fill: #85B7EB;"/>
         </VBox>
         <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="2"
               style="-fx-padding: 0 0 14 0;">
            <Label fx:id="statAmount" text="—"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #E6F1FB;"/>
            <Label text="TONG DA BID"
                   style="-fx-font-size: 10; -fx-text-fill: #85B7EB;"/>
         </VBox>
         <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="2"
               style="-fx-padding: 0 0 14 0;">
            <Label fx:id="statEnding" text="—"
                   style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #E6F1FB;"/>
            <Label text="SAP KET THUC"
                   style="-fx-font-size: 10; -fx-text-fill: #85B7EB;"/>
         </VBox>
      </HBox>
   </VBox>

   <!-- ===== TABS ===== -->
   <TabPane fx:id="mainTabPane"
            tabClosingPolicy="UNAVAILABLE"
            VBox.vgrow="ALWAYS">

      <!-- ══════════════════════════════════════
           TAB 1: ACTIVE AUCTIONS
      ══════════════════════════════════════ -->
      <Tab text="Active Auctions">
         <VBox spacing="12"
               style="-fx-background-color: #f0f2f5; -fx-padding: 16 20;"
               VBox.vgrow="ALWAYS">

            <HBox spacing="8" alignment="CENTER_LEFT">
               <TextField fx:id="searchField"
                          promptText="Tim kiem san pham dau gia..."
                          prefHeight="38" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                      -fx-border-color: #dce3ea;
                                      -fx-border-radius: 8; -fx-background-radius: 8;
                                      -fx-padding: 0 12; -fx-font-size: 13;"/>
               <Button fx:id="btnSearch" text="Search"
                       onAction="#handleSearch"
                       prefHeight="38" prefWidth="90"
                       style="-fx-background-color: #185FA5; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 13;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
               <Button fx:id="btnRefresh" text="Refresh"
                       onAction="#handleRefresh"
                       prefHeight="38" prefWidth="90"
                       style="-fx-background-color: white; -fx-text-fill: #555;
                                   -fx-border-color: #dce3ea; -fx-border-radius: 8;
                                   -fx-background-radius: 8; -fx-font-size: 13;
                                   -fx-cursor: hand;"/>
            </HBox>

            <!-- Filter chips -->
            <HBox spacing="8">
               <Button fx:id="filterAll" text="Tat ca"
                       onAction="#handleFilterAll"
                       style="-fx-background-color: #E6F1FB; -fx-text-fill: #185FA5;
                                   -fx-border-color: #85B7EB; -fx-border-radius: 20;
                                   -fx-background-radius: 20; -fx-font-size: 12;
                                   -fx-padding: 5 14; -fx-cursor: hand;"/>
               <Button fx:id="filterElectronics" text="Electronics"
                       onAction="#handleFilterElectronics"
                       style="-fx-background-color: white; -fx-text-fill: #666;
                                   -fx-border-color: #dce3ea; -fx-border-radius: 20;
                                   -fx-background-radius: 20; -fx-font-size: 12;
                                   -fx-padding: 5 14; -fx-cursor: hand;"/>
               <Button fx:id="filterArt" text="Art"
                       onAction="#handleFilterArt"
                       style="-fx-background-color: white; -fx-text-fill: #666;
                                   -fx-border-color: #dce3ea; -fx-border-radius: 20;
                                   -fx-background-radius: 20; -fx-font-size: 12;
                                   -fx-padding: 5 14; -fx-cursor: hand;"/>
               <Button fx:id="filterVehicle" text="Vehicle"
                       onAction="#handleFilterVehicle"
                       style="-fx-background-color: white; -fx-text-fill: #666;
                                   -fx-border-color: #dce3ea; -fx-border-radius: 20;
                                   -fx-background-radius: 20; -fx-font-size: 12;
                                   -fx-padding: 5 14; -fx-cursor: hand;"/>
               <Button fx:id="filterEnding" text="Sap ket thuc"
                       onAction="#handleFilterEnding"
                       style="-fx-background-color: white; -fx-text-fill: #666;
                                   -fx-border-color: #dce3ea; -fx-border-radius: 20;
                                   -fx-background-radius: 20; -fx-font-size: 12;
                                   -fx-padding: 5 14; -fx-cursor: hand;"/>
            </HBox>

            <!-- Controller add cards vào đây -->
            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
               <VBox fx:id="auctionContainer" spacing="8" style="-fx-padding: 2;"/>
            </ScrollPane>

         </VBox>
      </Tab>

      <!-- ══════════════════════════════════════
           TAB 2: MY AUCTIONS
      ══════════════════════════════════════ -->
      <Tab text="My Auctions">
         <VBox spacing="12"
               style="-fx-background-color: #f0f2f5; -fx-padding: 16 20;"
               VBox.vgrow="ALWAYS">

            <HBox spacing="8" alignment="CENTER_LEFT">
               <TextField fx:id="myAuctionSearchField"
                          promptText="Tim auction cua toi..."
                          prefHeight="38" HBox.hgrow="ALWAYS"
                          style="-fx-background-color: white;
                                      -fx-border-color: #dce3ea;
                                      -fx-border-radius: 8; -fx-background-radius: 8;
                                      -fx-padding: 0 12; -fx-font-size: 13;"/>
               <Button fx:id="btnCreateAuction" text="+ Tao moi"
                       onAction="#handleCreateAuction"
                       prefHeight="38"
                       style="-fx-background-color: #185FA5; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 13;
                                   -fx-background-radius: 8; -fx-cursor: hand;"/>
               <Button fx:id="btnRefreshMyAuction" text="Refresh"
                       onAction="#handleRefreshMyAuction"
                       prefHeight="38" prefWidth="90"
                       style="-fx-background-color: white; -fx-text-fill: #555;
                                   -fx-border-color: #dce3ea; -fx-border-radius: 8;
                                   -fx-background-radius: 8; -fx-font-size: 13;
                                   -fx-cursor: hand;"/>
            </HBox>

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
               <VBox spacing="0" style="-fx-padding: 2;">

                  <Label text="DANG HOAT DONG"
                         style="-fx-font-size: 10; -fx-font-weight: bold;
                                      -fx-text-fill: #3B6D11; -fx-padding: 2 0 7 2;"/>
                  <!-- Controller add card đang active vào đây -->
                  <VBox fx:id="myAuctionActiveContainer" spacing="8"/>

                  <Label text="DA KET THUC"
                         style="-fx-font-size: 10; -fx-font-weight: bold;
                                      -fx-text-fill: #aaa; -fx-padding: 14 0 7 2;"/>
                  <!-- Controller add card đã kết thúc vào đây -->
                  <VBox fx:id="myAuctionEndedContainer" spacing="8"/>

               </VBox>
            </ScrollPane>
         </VBox>
      </Tab>

      <!-- ══════════════════════════════════════
           TAB 3: MY BIDS
      ══════════════════════════════════════ -->
      <Tab text="My Bids">
         <VBox spacing="12"
               style="-fx-background-color: #f0f2f5; -fx-padding: 16 20;"
               VBox.vgrow="ALWAYS">

            <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                        style="-fx-background-color: transparent; -fx-border-color: transparent;">
               <VBox spacing="0" style="-fx-padding: 2;">

                  <Label text="DANG THANG"
                         style="-fx-font-size: 10; -fx-font-weight: bold;
                                      -fx-text-fill: #3B6D11; -fx-padding: 2 0 7 2;"/>
                  <!-- Controller add card đang thắng vào đây -->
                  <VBox fx:id="bidsWinningContainer" spacing="8"/>

                  <Label text="DANG THUA"
                         style="-fx-font-size: 10; -fx-font-weight: bold;
                                      -fx-text-fill: #A32D2D; -fx-padding: 14 0 7 2;"/>
                  <!-- Controller add card đang thua vào đây -->
                  <VBox fx:id="bidsLosingContainer" spacing="8"/>

                  <Label text="DA KET THUC"
                         style="-fx-font-size: 10; -fx-font-weight: bold;
                                      -fx-text-fill: #aaa; -fx-padding: 14 0 7 2;"/>
                  <!-- Controller add card đã kết thúc vào đây -->
                  <VBox fx:id="bidsEndedContainer" spacing="8"/>

               </VBox>
            </ScrollPane>
         </VBox>
      </Tab>

      <!-- ══════════════════════════════════════
           TAB 4: PROFILE
      ══════════════════════════════════════ -->
      <Tab text="Profile">
         <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                     style="-fx-background-color: #f0f2f5; -fx-border-color: transparent;">
            <VBox spacing="12"
                  style="-fx-background-color: #f0f2f5; -fx-padding: 16 20;">

               <!-- Hero card -->
               <HBox spacing="16" alignment="CENTER_LEFT"
                     style="-fx-background-color: white; -fx-border-color: #e0e6ee;
                                 -fx-border-radius: 10; -fx-background-radius: 10;
                                 -fx-padding: 18 20;">
                  <StackPane prefWidth="64" prefHeight="64"
                             style="-fx-background-color: #E6F1FB; -fx-background-radius: 32;">
                     <Label fx:id="lblAvatar" text="?"
                            style="-fx-font-size: 24; -fx-font-weight: bold;
                                          -fx-text-fill: #185FA5;"/>
                  </StackPane>
                  <VBox spacing="5" HBox.hgrow="ALWAYS">
                     <Label fx:id="profileName" text="—"
                            style="-fx-font-size: 16; -fx-font-weight: bold;
                                          -fx-text-fill: #1a2e44;"/>
                     <Label fx:id="profileEmail" text="—"
                            style="-fx-font-size: 12; -fx-text-fill: #888;"/>
                     <Label fx:id="profileRole" text="—"
                            style="-fx-background-color: #E6F1FB;
                                          -fx-text-fill: #0C447C; -fx-font-size: 11;
                                          -fx-padding: 3 10; -fx-background-radius: 20;"/>
                  </VBox>
                  <Button fx:id="btnEditProfile" text="Chinh sua"
                          onAction="#handleEditProfile"
                          style="-fx-background-color: white; -fx-text-fill: #555;
                                       -fx-border-color: #dce3ea; -fx-border-radius: 8;
                                       -fx-background-radius: 8; -fx-font-size: 12;
                                       -fx-cursor: hand;"/>
               </HBox>

               <!-- 3 stat mini -->
               <HBox spacing="10">
                  <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="3"
                        style="-fx-background-color: white; -fx-border-color: #e0e6ee;
                                     -fx-border-radius: 10; -fx-background-radius: 10;
                                     -fx-padding: 14;">
                     <Label fx:id="statProfileTotalBids" text="—"
                            style="-fx-font-size: 20; -fx-font-weight: bold;
                                          -fx-text-fill: #185FA5;"/>
                     <Label text="Tong luot bid"
                            style="-fx-font-size: 11; -fx-text-fill: #aaa;"/>
                  </VBox>
                  <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="3"
                        style="-fx-background-color: white; -fx-border-color: #e0e6ee;
                                     -fx-border-radius: 10; -fx-background-radius: 10;
                                     -fx-padding: 14;">
                     <Label fx:id="statProfileWins" text="—"
                            style="-fx-font-size: 20; -fx-font-weight: bold;
                                          -fx-text-fill: #3B6D11;"/>
                     <Label text="Da thang"
                            style="-fx-font-size: 11; -fx-text-fill: #aaa;"/>
                  </VBox>
                  <VBox alignment="CENTER" HBox.hgrow="ALWAYS" spacing="3"
                        style="-fx-background-color: white; -fx-border-color: #e0e6ee;
                                     -fx-border-radius: 10; -fx-background-radius: 10;
                                     -fx-padding: 14;">
                     <Label fx:id="statProfileActive" text="—"
                            style="-fx-font-size: 20; -fx-font-weight: bold;
                                          -fx-text-fill: #185FA5;"/>
                     <Label text="Dang tham gia"
                            style="-fx-font-size: 11; -fx-text-fill: #aaa;"/>
                  </VBox>
               </HBox>

               <!-- Thong tin ca nhan -->
               <VBox spacing="0"
                     style="-fx-background-color: white; -fx-border-color: #e0e6ee;
                                 -fx-border-radius: 10; -fx-background-radius: 10;
                                 -fx-padding: 16;">
                  <Label text="THONG TIN CA NHAN"
                         style="-fx-font-size: 10; -fx-font-weight: bold;
                                      -fx-text-fill: #aaa; -fx-padding: 0 0 12 0;"/>
                  <HBox style="-fx-padding: 9 0;
                                     -fx-border-color: transparent transparent #f5f7fa transparent;">
                     <Label text="Ho va ten"
                            style="-fx-font-size: 12; -fx-text-fill: #aaa;
                                          -fx-min-width: 150;"/>
                     <Label fx:id="profileFullName" text="—"
                            style="-fx-font-size: 13; -fx-font-weight: bold;
                                          -fx-text-fill: #1a2e44;"/>
                  </HBox>
                  <HBox style="-fx-padding: 9 0;
                                     -fx-border-color: transparent transparent #f5f7fa transparent;">
                     <Label text="Ten dang nhap"
                            style="-fx-font-size: 12; -fx-text-fill: #aaa;
                                          -fx-min-width: 150;"/>
                     <Label fx:id="profileUsername" text="—"
                            style="-fx-font-size: 13; -fx-font-weight: bold;
                                          -fx-text-fill: #1a2e44;"/>
                  </HBox>
                  <HBox style="-fx-padding: 9 0;
                                     -fx-border-color: transparent transparent #f5f7fa transparent;">
                     <Label text="Email"
                            style="-fx-font-size: 12; -fx-text-fill: #aaa;
                                          -fx-min-width: 150;"/>
                     <Label fx:id="profileEmailDetail" text="—"
                            style="-fx-font-size: 13; -fx-font-weight: bold;
                                          -fx-text-fill: #1a2e44;"/>
                  </HBox>
                  <HBox style="-fx-padding: 9 0;">
                     <Label text="Vai tro"
                            style="-fx-font-size: 12; -fx-text-fill: #aaa;
                                          -fx-min-width: 150;"/>
                     <Label fx:id="profileRoleDetail" text="—"
                            style="-fx-background-color: #E6F1FB;
                                          -fx-text-fill: #0C447C; -fx-font-size: 11;
                                          -fx-padding: 3 10; -fx-background-radius: 20;"/>
                  </HBox>
               </VBox>

               <!-- Bao mat -->
               <VBox spacing="0"
                     style="-fx-background-color: white; -fx-border-color: #e0e6ee;
                                 -fx-border-radius: 10; -fx-background-radius: 10;
                                 -fx-padding: 16;">
                  <Label text="BAO MAT"
                         style="-fx-font-size: 10; -fx-font-weight: bold;
                                      -fx-text-fill: #aaa; -fx-padding: 0 0 12 0;"/>
                  <HBox alignment="CENTER_LEFT" style="-fx-padding: 9 0;">
                     <Label text="Mat khau"
                            style="-fx-font-size: 12; -fx-text-fill: #aaa;
                                          -fx-min-width: 150;"/>
                     <Label text="••••••••"
                            style="-fx-font-size: 13; -fx-font-weight: bold;
                                          -fx-text-fill: #1a2e44;"
                            HBox.hgrow="ALWAYS"/>
                     <Button fx:id="btnChangePassword" text="Doi mat khau"
                             onAction="#handleChangePassword"
                             style="-fx-background-color: white; -fx-text-fill: #555;
                                           -fx-border-color: #dce3ea; -fx-border-radius: 8;
                                           -fx-background-radius: 8; -fx-font-size: 11;
                                           -fx-cursor: hand;"/>
                  </HBox>
               </VBox>

            </VBox>
         </ScrollPane>
      </Tab>

   </TabPane>
</VBox>