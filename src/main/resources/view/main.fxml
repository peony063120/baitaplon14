<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<VBox spacing="20" alignment="CENTER" xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.MainController">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <!-- Header -->
    <VBox alignment="CENTER" spacing="10">
        <Text text="Online Auction System" style="-fx-font-size: 28; -fx-font-weight: bold; -fx-fill: #2c3e50;"/>
        <Text text="Welcome to the auction platform" style="-fx-font-size: 14; -fx-fill: #7f8c8d;"/>
    </VBox>

    <!-- User Info -->
    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Label fx:id="userInfoLabel" style="-fx-font-size: 12; -fx-text-fill: #3498db;"/>
        <Button text="Logout" onAction="#handleLogout"
                style="-fx-background-color: #e74c3c; -fx-text-fill: white; -fx-font-size: 12; -fx-padding: 5 15;"/>
    </HBox>

    <!-- Tabs for different views -->
    <TabPane fx:id="tabPane">
        <!-- Active Auctions Tab -->
        <Tab text="Active Auctions" closable="false">
            <VBox spacing="15" alignment="TOP_CENTER">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <!-- Search and Filter -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="searchField" promptText="Search auctions..."
                               style="-fx-pref-width: 300; -fx-pref-height: 35; -fx-padding: 5 10;"/>
                    <Button text="Search" onAction="#handleSearch"
                            style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 5 15;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button text="Refresh" onAction="#handleRefresh"
                            style="-fx-background-color: #95a5a6; -fx-text-fill: white; -fx-padding: 5 15;"/>
                </HBox>

                <!-- Auction List -->
                <ListView fx:id="auctionListView"
                          style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 5;"
                          VBox.vgrow="ALWAYS"/>

                <!-- Status Label -->
                <Label fx:id="statusLabel" style="-fx-font-size: 12; -fx-text-fill: #7f8c8d;"/>
            </VBox>
        </Tab>

        <!-- My Auctions Tab (for Sellers) -->
        <Tab fx:id="myAuctionsTab" text="My Auctions" closable="false">
            <VBox spacing="15" alignment="TOP_CENTER">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="Create New Auction" onAction="#handleCreateAuction"
                            style="-fx-background-color: #27ae60; -fx-text-fill: white; -fx-padding: 8 20;"/>
                </HBox>

                <ListView fx:id="myAuctionsListView"
                          style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 5;"
                          VBox.vgrow="ALWAYS"/>
            </VBox>
        </Tab>

        <!-- My Bids Tab -->
        <Tab text="My Bids" closable="false">
            <VBox spacing="15" alignment="TOP_CENTER">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <ListView fx:id="myBidsListView"
                          style="-fx-background-color: white; -fx-border-color: #e0e0e0; -fx-border-radius: 5;"
                          VBox.vgrow="ALWAYS"/>
            </VBox>
        </Tab>

        <!-- Profile Tab -->
        <Tab text="Profile" closable="false">
            <VBox spacing="20" alignment="TOP_CENTER">
                <padding>
                    <Insets top="20" right="20" bottom="20" left="20"/>
                </padding>

                <GridPane hgap="20" vgap="15" alignment="CENTER">
                    <Label text="Username:" GridPane.rowIndex="0" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                    <Label fx:id="profileUsername" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <Label text="Full Name:" GridPane.rowIndex="1" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                    <Label fx:id="profileFullName" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <Label text="Email:" GridPane.rowIndex="2" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                    <Label fx:id="profileEmail" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <Label text="Role:" GridPane.rowIndex="3" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                    <Label fx:id="profileRole" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                    <Label text="Balance:" GridPane.rowIndex="4" GridPane.columnIndex="0" style="-fx-font-weight: bold;"/>
                    <Label fx:id="profileBalance" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                </GridPane>

                <Button text="Refresh Profile" onAction="#handleRefreshProfile"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-padding: 8 20;"/>
            </VBox>
        </Tab>
    </TabPane>
</VBox>