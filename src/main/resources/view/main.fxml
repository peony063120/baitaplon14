<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Text?>

<?import javafx.collections.FXCollections?>
<?import java.lang.String?>
<VBox alignment="CENTER" spacing="20" style="-fx-background-color: #0D1B2A;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.auction.client.controller.LoginController">
    <padding><Insets top="40" right="40" bottom="40" left="40"/></padding>
    <Text text="🪙 BidVN" style="-fx-font-family: 'Playfair Display'; -fx-font-size: 32; -fx-fill: #F0D080; -fx-font-weight: bold;"/>
    <Text text="Đăng nhập" style="-fx-fill: white; -fx-font-size: 18;"/>
    <TextField fx:id="usernameField" promptText="Tên đăng nhập" styleClass="login-field"/>
    <PasswordField fx:id="passwordField" promptText="Mật khẩu" styleClass="login-field"/>
    <ComboBox fx:id="roleCombo" styleClass="login-field">
        <items><FXCollections fx:factory="observableArrayList"><String fx:value="BIDDER"/><String fx:value="SELLER"/><String fx:value="ADMIN"/></FXCollections></items>
        <value>BIDDER</value>
    </ComboBox>
    <Button fx:id="loginButton" text="Đăng nhập" styleClass="login-btn" onAction="#onLogin"/>
    <Hyperlink text="Chưa có tài khoản? Đăng ký ngay" onAction="#onRegister" style="-fx-text-fill: #C9A84C;"/>
    <Label fx:id="messageLabel" textFill="red"/>
</VBox>