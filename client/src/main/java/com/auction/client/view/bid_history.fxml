<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.BidHistoryController"
            stylesheets="@../styles/main.css">
    <center>
        <VBox spacing="16" styleClass="content-page">
            <padding>
                <Insets top="24" right="24" bottom="24" left="24"/>
            </padding>
            <Text text="Bid History" styleClass="page-title"/>
            <HBox spacing="12" alignment="CENTER_LEFT" styleClass="surface">
                <DatePicker fx:id="fromDatePicker" promptText="From Date"/>
                <DatePicker fx:id="toDatePicker" promptText="To Date"/>
                <Button text="Filter" styleClass="primary-btn" onAction="#handleFilter"/>
                <Button text="Reset" styleClass="secondary-btn" onAction="#handleResetFilter"/>
                <Button text="Export CSV" styleClass="secondary-btn" onAction="#handleExportCSV"/>
                <Button text="Sort Asc" styleClass="secondary-btn" onAction="#handleSortAsc"/>
                <Button text="Sort Desc" styleClass="secondary-btn" onAction="#handleSortDesc"/>
            </HBox>
            <Label fx:id="statusLabel" styleClass="muted-text"/>
            <TableView fx:id="historyTable" styleClass="data-table">
                <columns>
                    <TableColumn text="Bidder" fx:id="bidderColumn" prefWidth="200"/>
                    <TableColumn text="Amount" fx:id="amountColumn" prefWidth="150"/>
                    <TableColumn text="Time" fx:id="timeColumn" prefWidth="200"/>
                    <TableColumn text="Auto Bid" fx:id="autoBidColumn" prefWidth="100"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
