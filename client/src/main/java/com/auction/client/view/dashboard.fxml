<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED" styleClass="dashboard-scroll"
            xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.auction.client.controller.DashboardController">
    <VBox spacing="12" styleClass="content-page">
        <padding>
            <Insets top="16" right="24" bottom="24" left="24"/>
        </padding>

        <HBox spacing="16" styleClass="stats-row">
            <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS">
                <Text text="Total Revenue" styleClass="stat-label"/>
                <Label fx:id="totalRevenue" styleClass="stat-value"/>
                <Text text="Completed auction value" styleClass="muted-text"/>
            </VBox>
            <VBox styleClass="stat-card" spacing="6" HBox.hgrow="ALWAYS">
                <Text text="Active Auctions" styleClass="stat-label"/>
                <Label fx:id="activeAuctionsCount" styleClass="stat-value"/>
                <Text text="Currently running" styleClass="muted-text"/>
            </VBox>
        </HBox>

        <VBox spacing="8">
            <Text text="Revenue Overview" styleClass="section-title"/>
            <LineChart fx:id="revenueChart" prefHeight="200" minHeight="180" maxHeight="220"
                       maxWidth="Infinity" styleClass="revenue-chart" VBox.vgrow="NEVER">
                <xAxis>
                    <NumberAxis label="Day"/>
                </xAxis>
                <yAxis>
                    <NumberAxis label="Amount"/>
                </yAxis>
            </LineChart>
        </VBox>

        <HBox spacing="8" styleClass="filter-tabs">
            <ToggleButton fx:id="filterAll" text="All" styleClass="filter-tab" selected="true"
                          onAction="#filterBySort" userData="all"/>
            <ToggleButton fx:id="filterEnding" text="Ending Soon" styleClass="filter-tab"
                          onAction="#filterBySort" userData="ending"/>
            <ToggleButton fx:id="filterNewest" text="Newest" styleClass="filter-tab"
                          onAction="#filterBySort" userData="newest"/>
            <ToggleButton fx:id="filterHighest" text="Highest Bid" styleClass="filter-tab"
                          onAction="#filterBySort" userData="highest"/>
        </HBox>

        <TilePane fx:id="auctionGrid" prefColumns="3" hgap="20" vgap="20"/>
    </VBox>
</ScrollPane>
