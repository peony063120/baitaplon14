<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Text?>

<BorderPane stylesheets="@../styles/main.css" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.auction.client.controller.MainController">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="24" styleClass="dashboard-header">
            <padding>
                <Insets bottom="16" left="28" right="28" top="16" />
            </padding>
         <ImageView fitHeight="92.0" fitWidth="60.0" pickOnBounds="true" preserveRatio="true" scaleX="1.1" scaleY="1.1">
            <image>
               <Image url="@Logo-7.PNG" />
            </image>
            <HBox.margin>
               <Insets left="10.0" right="-15.0" />
            </HBox.margin>
         </ImageView>
            <HBox alignment="CENTER_LEFT" onMouseClicked="#showDashboard" spacing="8" />
            <TextField fx:id="searchField" onAction="#handleSearch" promptText="Search auctions..." styleClass="search-field" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="clockLabel" styleClass="clock" />
            <Button fx:id="notifBtn" onAction="#showNotifications" styleClass="icon-btn" text="!" />
            <Button fx:id="avatarBtn" onAction="#showProfile" styleClass="avatar-btn" text="U" />
            <Button onAction="#onLogout" styleClass="logout-btn" text="Logout" />
        </HBox>
    </top>
    <left>
        <VBox spacing="12" styleClass="dashboard-sidebar">
            <padding>
                <Insets bottom="28" left="16" right="16" top="28" />
            </padding>
            <VBox spacing="8" styleClass="wallet-card">
                <Text styleClass="muted-text" text="Available Balance" />
                <Text fx:id="balanceLabel" styleClass="wallet-amount" />
                <HBox spacing="10">
                    <Button onAction="#onDeposit" styleClass="wallet-btn deposit" text="Deposit" />
                    <Button onAction="#onWithdraw" styleClass="wallet-btn withdraw" text="Withdraw" />
                </HBox>
            </VBox>
            <VBox spacing="4">
                <Text styleClass="nav-title" text="MENU" />
                <ToggleButton fx:id="homeNav" onAction="#showDashboard" styleClass="nav-item" text="Dashboard" />
                <ToggleButton fx:id="liveNav" onAction="#showLive" styleClass="nav-item" text="Live Auctions" />
                <ToggleButton fx:id="historyNav" onAction="#showHistory" styleClass="nav-item" text="My Bids" />
                <ToggleButton fx:id="walletNav" onAction="#showWallet" styleClass="nav-item" text="Wallet" />
                <ToggleButton fx:id="profileNav" onAction="#showProfile" styleClass="nav-item" text="Profile" />
            </VBox>
            <VBox fx:id="sellerMenu" managed="false" spacing="4" visible="false">
                <Text styleClass="nav-title" text="SELLER" />
                <ToggleButton onAction="#showCreateAuction" styleClass="nav-item" text="Create Auction" />
                <ToggleButton onAction="#showMyAuctions" styleClass="nav-item" text="My Auctions" />
            </VBox>
            <VBox spacing="4">
                <Text styleClass="nav-title" text="CATEGORIES" />
                <ToggleButton fx:id="catAll" onAction="#filterByCategory" styleClass="cat-item" text="All" userData="all" />
                <ToggleButton fx:id="catXe" onAction="#filterByCategory" styleClass="cat-item" text="Vehicles" userData="Vehicles" />
                <ToggleButton fx:id="catDienTu" onAction="#filterByCategory" styleClass="cat-item" text="Electronics" userData="Electronics" />
                <ToggleButton fx:id="catNgheThuat" onAction="#filterByCategory" styleClass="cat-item" text="Art" userData="Art" />
                <ToggleButton fx:id="catTrangSuc" onAction="#filterByCategory" styleClass="cat-item" text="Jewelry" userData="Jewelry" />
                <ToggleButton fx:id="catBatDongSan" onAction="#filterByCategory" styleClass="cat-item" text="Real Estate" userData="Real Estate" />
                <ToggleButton fx:id="catDongHo" onAction="#filterByCategory" styleClass="cat-item" text="Watches" userData="Watches" />
                <ToggleButton fx:id="catCoVat" onAction="#filterByCategory" styleClass="cat-item" text="Antiques" userData="Antiques" />
            </VBox>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentPane" styleClass="dashboard-content" />
    </center>
</BorderPane>
